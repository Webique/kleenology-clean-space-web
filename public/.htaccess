RewriteEngine On
RewriteBase /

# =============================================================================
# 1. BLOCK DANGEROUS HTTP METHODS
# =============================================================================
# TRACE enables XST (Cross-Site Tracing) attacks that steal cookies.
# TRACK is Microsoft's variant of TRACE.
# CONNECT is used for proxy tunneling.
# DEBUG is an IIS-specific method exploited for remote code execution.
RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK|CONNECT|DEBUG) [NC]
RewriteRule ^ - [F,L]

# =============================================================================
# 2. BLOCK SCANNERS & PENTEST TOOLS BY USER-AGENT
# =============================================================================
RewriteCond %{HTTP_USER_AGENT} "(nmap|Nmap Scripting Engine|masscan|zgrab|zmap)" [NC,OR]
RewriteCond %{HTTP_USER_AGENT} "(nikto|nuclei|acunetix|netsparker|appscan|webinspect)" [NC,OR]
RewriteCond %{HTTP_USER_AGENT} "(nessus|openvas|qualys|rapid7|burp|burpsuite)" [NC,OR]
RewriteCond %{HTTP_USER_AGENT} "(ffuf|Fuzz Faster U Fool|dirsearch|dirbuster|gobuster)" [NC,OR]
RewriteCond %{HTTP_USER_AGENT} "(feroxbuster|wfuzz|rustbuster|kiterunner)" [NC,OR]
RewriteCond %{HTTP_USER_AGENT} "(sqlmap|metasploit|hydra|medusa|ncrack|commix|dalfox|xsser)" [NC,OR]
RewriteCond %{HTTP_USER_AGENT} "(w3af|wapiti|skipfish|arachni|whatweb)" [NC,OR]
RewriteCond %{HTTP_USER_AGENT} "(httpx/|katana/|hakrawler|gau/)" [NC,OR]
RewriteCond %{HTTP_USER_AGENT} "(python-requests/|python-urllib/|go-http-client/)" [NC,OR]
RewriteCond %{HTTP_USER_AGENT} "(libwww-perl|lwp-trivial|jakarta commons)" [NC,OR]
RewriteCond %{HTTP_USER_AGENT} "(owasp|zap/|shodan|censys)" [NC,OR]
RewriteCond %{HTTP_USER_AGENT} "^(curl/|wget/|python/|ruby )" [NC]
RewriteRule ^ - [F,L]

# =============================================================================
# 3. WAF – BLOCK ATTACK PAYLOADS IN URL
# =============================================================================

# Path traversal
RewriteCond %{REQUEST_URI} "\.\.[/\\]" [OR]
RewriteCond %{QUERY_STRING} "(\.\.\/|\.\.%2[fF]|\.\.%5[cC])" [OR]

# SQL injection
RewriteCond %{QUERY_STRING} "(union.*select|select.*from|drop.*table|insert.*into|delete.*from)" [NC,OR]
RewriteCond %{QUERY_STRING} "(exec|execute|xp_cmdshell|sp_executesql)" [NC,OR]
RewriteCond %{QUERY_STRING} "(%27|').*(%20|[\s])(or|and)[\s]" [NC,OR]

# XSS
RewriteCond %{QUERY_STRING} "(<script|javascript:|vbscript:|onload=|onerror=|onclick=)" [NC,OR]
RewriteCond %{QUERY_STRING} "(<iframe|<object|&#x[0-9a-f])" [NC,OR]

# LFI / RFI
RewriteCond %{QUERY_STRING} "(etc/passwd|etc/shadow|proc/self)" [NC,OR]
RewriteCond %{QUERY_STRING} "=(https?|ftp|php)://" [NC,OR]

# Command injection
RewriteCond %{QUERY_STRING} "([;|`].*(ls|cat|id|whoami|wget|curl|bash))" [NC,OR]

# XXE
RewriteCond %{QUERY_STRING} "(<!ENTITY|SYSTEM\s+\"(file|http|ftp))" [NC]

RewriteRule ^ - [F,L]

# =============================================================================
# 4. BLOCK PROBE PATHS (scanner honey-trap targets)
# =============================================================================
RewriteCond %{REQUEST_URI} "^/(\.git|\.svn|\.hg)" [OR]
RewriteCond %{REQUEST_URI} "^/\.env($|\.)" [OR]
RewriteCond %{REQUEST_URI} "^/(HNAP1|sdk/info|evox/about)" [OR]
RewriteCond %{REQUEST_URI} "^/(wp-login\.php|wp-admin|wp-config\.php)" [OR]
RewriteCond %{REQUEST_URI} "^/(phpmyadmin|phpinfo\.php|php-info\.php)" [OR]
RewriteCond %{REQUEST_URI} "^/(server-status|server-info)" [OR]
RewriteCond %{REQUEST_URI} "^/(actuator|_profiler|manager/html)" [OR]
RewriteCond %{REQUEST_URI} "^/WEB-INF/" [OR]
RewriteCond %{REQUEST_URI} "^/(backup\.|dump\.sql|database\.sql|db\.sql)" [OR]
RewriteCond %{REQUEST_URI} "^/(\.DS_Store|Thumbs\.db|\.htpasswd)" [OR]
RewriteCond %{REQUEST_URI} "^/(crossdomain\.xml|clientaccesspolicy\.xml)" [OR]
RewriteCond %{REQUEST_URI} "^/latest/meta-data" [NC]
RewriteRule ^ - [F,L]

# =============================================================================
# 5. SECURITY HEADERS – HIDE SERVER FINGERPRINTING INFORMATION
# =============================================================================
<IfModule mod_headers.c>
  Header always unset X-Powered-By
  Header always unset Server
  Header always unset Via
  Header always unset X-AspNet-Version
  Header always unset X-AspNetMvc-Version
  Header always set Server "Web Server"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Download-Options "noopen"
  Header always set X-Permitted-Cross-Domain-Policies "none"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# =============================================================================
# 6. SPA FALLBACK ROUTING
# =============================================================================
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-l
RewriteRule . /index.html [L]
